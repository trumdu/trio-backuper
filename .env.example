# App
APP_NAME=copycon-backuper
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# Persistence
DB_PATH=/data/app.db
LOG_DIR=/data/logs
BACKUP_ROOT=/data/backups

# Security (generate once; keep secret)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_FERNET_KEY=PLEASE_SET_ME

# Backup behavior
MAX_CONCURRENT_JOBS=2
RUN_LOG_MAX_CHARS=20000

# Retention
# Set either MAX_BACKUP_AGE_DAYS or MAX_BACKUP_TOTAL_BYTES (or both)
MAX_BACKUP_AGE_DAYS=30
MAX_BACKUP_TOTAL_BYTES=
